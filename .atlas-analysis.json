  "keyFeatures": [
    "Async browser automation without Selenium or ChromeDriver",
    "Built-in anti-detection bypassing Captcha, CloudFlare, and bot systems",
    "Direct Chrome DevTools Protocol (CDP) communication",
    "Smart element finding by text and CSS selectors with auto-retry",
    "Cookie management and local storage support",
    "Multi-tab and multi-window control",
    "Screenshot and DOM manipulation",
    "XPath selector support",
    "CloudFlare verification helper methods"
  ],
